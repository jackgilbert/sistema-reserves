{
  "name": "sistema-reservas",
  "version": "1.0.0",
  "description": "Sistema de reservas multi-tenant",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm -C packages/db db:generate",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:seed": "pnpm -C packages/db db:seed",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "reservas",
    "multi-tenant",
    "nestjs",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/throttler": "^6.5.0",
    "@zxing/browser": "^0.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "multer": "^2.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/multer": "^2.0.0",
    "@types/uuid": "^11.0.0",
    "typescript": "5.7.2"
  }
}
